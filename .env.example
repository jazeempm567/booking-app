# Zahi Spa - Environment Variables Template
# Copy this to .env.production and fill in your actual keys
# DO NOT commit .env.production to Git - it's in .gitignore

# Stripe API Keys (Get from https://dashboard.stripe.com/apikeys)
# For Testing: Use sk_test_* and pk_test_* keys
# For Production: Use sk_live_* and pk_live_* keys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Server Configuration
PORT=3000
NODE_ENV=production
